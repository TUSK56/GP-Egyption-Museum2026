{
    "ConnectionStrings": {
        "DefaultConnection": "Server=localhost,1433;Database=VirtualMuseumDB;User ID=sa;Password=ChangeThisInEnv!;TrustServerCertificate=True;Encrypt=False;MultipleActiveResultSets=true;"
    },
    "Jwt": {
        "Key": "ChangeThisJwtKeyInEnvironmentVariables-Minimum32Chars!",
        "Issuer": "VirtualMuseum.API",
        "Audience": "VirtualMuseum.Client",
        "AccessTokenMinutes": 60,
        "RefreshTokenDays": 7
    },
    "Smtp": {
        "Enabled": "false",
        "SmtpServer": "smtp.example.com",
        "Port": "587",
        "SenderName": "Virtual Museum",
        "SenderEmail": "no-reply@example.com",
        "Username": "smtp-username",
        "Password": "smtp-password"
    },
    "Cors": {
        "Origins": [
            "http://localhost:3000",
            "http://localhost:5173",
            "http://127.0.0.1:5173"
        ]
    },
    "GoogleAuth": {
        "ClientId": "replace-with-google-oauth-client-id.apps.googleusercontent.com"
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
            "VirtualMuseum": "Information"
        }
    },
    "AllowedHosts": "*"
}
